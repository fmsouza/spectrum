{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "typecheck": { "dependsOn": ["^build"], "outputs": [], "cache": true },
    "test": { "dependsOn": ["^build"], "outputs": [], "cache": true },
    "lint": { "outputs": [], "cache": true }
  }
}
