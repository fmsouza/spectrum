{
  "name": "launchkit",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "bin": {
    "launchkit": "./src/cli.ts"
  },
  "scripts": {
    "build": "electrobun build",
    "start": "electrobun dev",
    "dev": "electrobun dev --watch",
    "compile": "bun build --compile --minify --outfile dist/launchkit-cli ./src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "bun test"
  },
  "dependencies": {
    "@launchkit/agent-driver": "workspace:*",
    "@launchkit/driver-claude": "workspace:*",
    "@launchkit/driver-codex": "workspace:*",
    "@launchkit/driver-opencode": "workspace:*",
    "@launchkit/agent-events": "workspace:*",
    "@launchkit/run-store": "workspace:*",
    "@launchkit/cli": "workspace:*",
    "@launchkit/projects": "workspace:*",
    "@launchkit/config": "workspace:*",
    "@launchkit/db": "workspace:*",
    "@launchkit/harnesses": "workspace:*",
    "@launchkit/ipc": "workspace:*",
    "@launchkit/proxy": "workspace:*",
    "@launchkit/pty": "workspace:*",
    "@launchkit/secrets": "workspace:*",
    "@launchkit/sessions": "workspace:*",
    "@launchkit/types": "workspace:*",
    "@launchkit/ui": "workspace:*",
    "@launchkit/utils": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "electrobun": "^1.18.1",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
