{
  "name": "spectrum-monorepo",
  "version": "1.1.2",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "zod": "^3.25.76",
      "drizzle-orm": "^0.45.2",
      "react": "^19.2.6",
      "react-dom": "^19.2.6"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "test": "bun test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "version": "bun scripts/sync-workspace-versions.ts && biome check --write . && git add -u",
    "release:patch": "npm version patch --ignore-scripts=false",
    "release:minor": "npm version minor --ignore-scripts=false",
    "release:major": "npm version major --ignore-scripts=false"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@happy-dom/global-registrator": "^20",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20",
    "react": "catalog:",
    "react-dom": "catalog:",
    "turbo": "^2.9.15",
    "typescript": "5.8.3"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "jsondiffpatch": "^0.7.2",
    "esbuild": "^0.28.1"
  }
}
