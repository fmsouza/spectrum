{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["./tooling/biome-config/biome.json"],
  "files": {
    "ignore": [
      "**/.claude/**",
      "**/.worktrees/**",
      "**/dist/**",
      "**/build/**",
      "**/artifacts/**",
      "**/.turbo/**",
      "**/node_modules/**",
      "**/src/migrations/**",
      "packages/driver-codex/src/bindings/**",
      "apps/desktop/views/main/xterm.css",
      "apps/desktop/scripts/verify-rail-roster.mjs",
      "apps/desktop/scripts/verify-rail-roster-entry.ts"
    ]
  },
  "overrides": [
    {
      "include": ["**/package.json"],
      "formatter": { "enabled": false }
    }
  ]
}
